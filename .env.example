# Storage type: sqlite, file, or json
STORAGE_TYPE=sqlite

# SQLite configuration (only used when STORAGE_TYPE=sqlite)
SQLITE_DB_PATH=database.sqlite

# File storage configuration (only used when STORAGE_TYPE=file)
FILE_PATH=data.txt

# JSON storage configuration (only used when STORAGE_TYPE=json)
JSON_PATH=data.json

# Index file path (used by file and json storage types)
INDEX_FILE_PATH=int.idx

# Server port
PORT=3000
